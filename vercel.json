{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "index.html",
          "po-management.html",
          "style.css",
          "po-management.css",
          "script.js",
          "po-management.js",
          "logo.png",
          "signature.png"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/server.js" }
  ]
}
